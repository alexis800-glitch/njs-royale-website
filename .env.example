# NJS Royale × Aiosell — environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local or any
# real credentials — sandbox and production secrets live only in .env.local
# (gitignored) and in Vercel environment variables.

# Neon Postgres connection string (postgresql://user:password@host/db?sslmode=require)
DATABASE_URL=

# Aiosell channel manager
AIOSELL_BASE_URL=https://live.aiosell.com
AIOSELL_PARTNER_ID=sample-ota

# Hotel code is CONFIGURABLE because Aiosell's docs and support gave
# different values (docs: SANDBOX-OTA, support: sandbox-pms). Set whichever
# the sandbox actually accepts; never hardcode it in application logic.
AIOSELL_HOTEL_CODE=

# HTTP Basic Auth for outbound calls to Aiosell (sandbox credentials issued
# 2026-07-11; values live ONLY here and in Vercel env vars)
AIOSELL_USERNAME=
AIOSELL_PASSWORD=

AIOSELL_CHANNEL_NAME=NJSResortWebsite

# Which seeded rate-plan code set is active: "docs" (EXECUTIVE-S-101 style,
# default) or "support" (executive-s-ep style). Re-run `npm run db:seed`
# after changing.
AIOSELL_RATEPLAN_SET=docs

# Shared secret guarding /api/dev/* routes. Sent as the `x-dev-secret`
# HEADER (never a query parameter). Routes are hard-disabled in Production
# regardless of this value, and fail closed if it is unset.
DEV_SECRET=

# /admin/debug protection: HTTP Basic Auth password (any username). The view
# fails closed if unset, and returns 404 in Production unless
# ADMIN_DEBUG_ENABLED=true is explicitly set.
ADMIN_DEBUG_PASSWORD=
ADMIN_DEBUG_ENABLED=
